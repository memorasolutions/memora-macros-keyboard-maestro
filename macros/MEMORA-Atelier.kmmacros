			<key>Actions</key>
			<array>
				<dict>
					<key>ActionUID</key>
					<integer>156221</integer>
					<key>DisplayKind</key>
					<string>None</string>
					<key>HonourFailureSettings</key>
					<true/>
					<key>IncludeStdErr</key>
					<false/>
					<key>IncludedVariables</key>
					<array>
						<string>9999</string>
					</array>
					<key>MacroActionType</key>
					<string>ExecuteAppleScript</string>
					<key>NotifyOnFailure</key>
					<false/>
					<key>Path</key>
					<string></string>
					<key>StopOnFailure</key>
					<false/>
					<key>Text</key>
					<string>tell application "Keyboard Maestro Engine"
	set theAction to getvariable "memora_at_action"
	set targetID to getvariable "memora_at_target"
end tell
if targetID is "" then return
if theAction is "delete" then
	tell application "Keyboard Maestro" to delete macro id targetID
else if theAction is "edit" then
	tell application "Keyboard Maestro" to editMacro targetID
end if
return "OK"</string>
					<key>TimeOutAbortsMacro</key>
					<true/>
					<key>TrimResults</key>
					<true/>
					<key>TrimResultsNew</key>
					<true/>
					<key>UseText</key>
					<true/>
				</dict>
			</array>
